#!/usr/bin/env bash
# Rename the current tmux window, but only if the user hasn't manually renamed it.
# Usage: tmux-rename-window <new-name>
#        tmux-rename-window --force <new-name>
#
# Convention:
#   @claude_window_name  — tmux window variable storing the last name Claude set.
#   If the current window name differs from that value, the user manually renamed it → skip.
#   Pass --force to override regardless.

set -euo pipefail

if [ -z "${TMUX:-}" ]; then
    echo "Not in a tmux session" >&2
    exit 1
fi

FORCE=0
if [ "${1:-}" = "--force" ]; then
    FORCE=1
    shift
fi

NEW_NAME="${1:-}"
if [ -z "$NEW_NAME" ]; then
    echo "Usage: tmux-rename-window [--force] <name>" >&2
    exit 1
fi

CURRENT_NAME=$(tmux display-message -p '#W')
CLAUDE_SET_NAME=$(tmux show-options -wv @claude_window_name 2>/dev/null || true)

if [ "$FORCE" -eq 0 ] && [ -n "$CLAUDE_SET_NAME" ] && [ "$CURRENT_NAME" != "$CLAUDE_SET_NAME" ]; then
    # User manually renamed the window — respect it
    exit 0
fi

tmux set-option -w automatic-rename off
tmux rename-window "$NEW_NAME"
tmux set-option -w @claude_window_name "$NEW_NAME"
